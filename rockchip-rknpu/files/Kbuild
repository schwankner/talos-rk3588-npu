# Kbuild for rknpu out-of-tree module.
#
# Patched from upstream w568w/rknpu-module:
#
# 1. rknpu_devfreq.o is excluded from compilation.
#    The Talos 1.12.x kernel-build stage exports /src without
#    include/linux/devfreq-governor.h even though CONFIG_PM_DEVFREQ=y in
#    autoconf.h, so the .c file cannot be compiled.
#
# 2. -DRKNPU_NO_DEVFREQ is added.
#    With CONFIG_PM_DEVFREQ=y, rknpu_devfreq.h emits real function
#    *declarations* (not inline stubs), which causes modpost to fail with
#    "undefined symbol" when the .o is absent.  The author provided
#    RKNPU_NO_DEVFREQ as an explicit escape hatch: when defined, the header
#    always emits the inline no-op stubs regardless of CONFIG_PM_DEVFREQ.
#
# 3. -DCONFIG_ROCKCHIP_RKNPU_DMA_HEAP is added (DRM_GEM is NOT set).
#    These two flags are mutually exclusive: rknpu_submit_ioctl is declared
#    with incompatible signatures under each path, causing "conflicting types"
#    compile errors when both are set.
#    DMA_HEAP is required so that misc_register() is called in rknpu_drv.c,
#    creating /dev/rknpu.  librknnrt.so v2.3.x opens /dev/rknpu and submits
#    inference jobs via the BSP ioctl interface (type='r').  With DRM_GEM only,
#    the driver creates /dev/dri/renderD* and /dev/dri/card* which librknnrt
#    cannot use.
#    The DRM device is still registered (drm_dev_register is not conditional),
#    so /sys/bus/platform/drivers/RKNPU/fdab0000.rknpu/drm/ still exists for
#    device-plugin discovery.
#
# 4. linux/rk-dma-heap.h stub is provided in src/include/compat/linux/.
#    The rk-dma-heap API is Rockchip BSP-only and absent from mainline 6.x.
#    The stub supplies static inline no-ops so the DMA_HEAP code path compiles;
#    heap allocation fails gracefully at runtime (rk_dma_heap_find returns NULL).

obj-m := rknpu.o
rknpu-y := src/rknpu_drv.o src/rknpu_gem.o src/rknpu_fence.o \
           src/rknpu_job.o src/rknpu_reset.o src/rknpu_iommu.o \
           src/rknpu_debugger.o src/rknpu_mem.o

ccflags-y += -I$(src)/src/include
ccflags-y += -I$(src)/src/include/compat
# Force DMA_HEAP / suppress DRM_GEM via a source-level force-include.
#
# GCC processes all -D/-U command-line flags BEFORE any -include files,
# so a bare -UCONFIG_ROCKCHIP_RKNPU_DRM_GEM in ccflags-y is overridden
# by autoconf.h's #define (loaded via KBUILD_CFLAGS' -include linux/kconfig.h).
# rknpu_build_config.h is a second -include that comes AFTER linux/kconfig.h
# in the compiler invocation (ccflags-y appends after KBUILD_CFLAGS), so its
# #undef CONFIG_ROCKCHIP_RKNPU_DRM_GEM executes after autoconf.h and wins.
ccflags-y += -include $(src)/src/include/compat/rknpu_build_config.h
ccflags-y += -DCONFIG_ROCKCHIP_RKNPU_DMA_HEAP
ccflags-y += -DCONFIG_ROCKCHIP_RKNPU_DEBUG_FS
ccflags-y += -DCONFIG_ROCKCHIP_RKNPU_FENCE
ccflags-y += -DRKNPU_NO_DEVFREQ
